    "@fastify/swagger-ui": "4.1.0",
    "@fastify/websocket": "10.0.1",
    "@flowpay/shared": "*",
    "async-mutex": "0.5.0",
    "fastify": "4.28.1",
    "pino": "9.3.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.15",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "fast-check": "3.19.0",
    "pino-pretty": "11.2.2",
    "tsx": "4.17.0",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
