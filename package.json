{
  "name": "flowpay",
  "version": "0.1.0",
  "private": true,
  "description": "FlowPay - Software de distribuição e monitoramento de atendimentos",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:api": "npm run dev --workspace @flowpay/api",
    "dev:web": "npm run dev --workspace @flowpay/web"
  },
  "devDependencies": {
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
